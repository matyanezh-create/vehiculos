{
  "info": {
    "name": "Sucursal vehiculos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:9090/vehiculosBuild"
    }
  ],
  "item": [
    {
      "name": "Validar API funcionando",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Estado HTTP 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Version 1.1', function () { pm.expect(pm.response.text()).to.include('Version 1.1'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Listar vehiculos",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/vehiculos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Estado HTTP 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Respuesta JSON', function () { pm.response.to.be.json; });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Validar OpenAPI",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api-docs"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Estado HTTP 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Documento OpenAPI', function () { pm.expect(pm.response.json().openapi).to.exist; });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
